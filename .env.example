# Analytics — wired into the template by default. Leave as "none" to run with a
# dev-only console logger; switch to a provider when the experiment goes public.
#
# Options: none | plausible | umami
VITE_ANALYTICS_PROVIDER=none

# Plausible: the site domain you registered (e.g. myexperiment.00-lab.dev)
# VITE_ANALYTICS_PROVIDER=plausible
# VITE_ANALYTICS_DOMAIN=

# Umami: your website id, and (for self-hosted) the script URL
# VITE_ANALYTICS_PROVIDER=umami
# VITE_ANALYTICS_WEBSITE_ID=
# VITE_ANALYTICS_SRC=https://cloud.umami.is/script.js
